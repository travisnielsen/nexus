FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project-name
FOUNDRY_MODEL=gpt-4.1-mini
PORT=5002

# Authentication
# AZURE_AD_CLIENT_ID: The Backend API app registration's Application (client) ID
AZURE_AD_CLIENT_ID=your-backend-api-client-id
# AZURE_AD_TENANT_ID: The Directory (tenant) ID shared across all app registrations
AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_API_SCOPE_URI: Fully qualified scope URI exposed by the Backend API app registration
# Format: api://<backend-app-guid>/<scope-name>  (no trailing slash)
# Must match NEXT_PUBLIC_AZURE_AD_API_SCOPE_URI in the frontend .env.local
AZURE_AD_API_SCOPE_URI=api://your-backend-app-id/access_as_user
AUTH_ENABLED=true

# OpenTelemetry / App Insights
ENABLE_INSTRUMENTATION=true
TELEMETRY_MODE=appinsights
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
ENABLE_SENSITIVE_DATA=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
