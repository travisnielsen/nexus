# MCP Server Configuration
# Copy this file to .env and fill in the values

# Server settings
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Authentication (Entra ID / Azure AD)
# Set AUTH_ENABLED=true to require JWT tokens on API requests
AUTH_ENABLED=false
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
# AZURE_AD_API_SCOPE_URI: Fully qualified scope URI for this service's app registration
# Format: api://<client-id>/<scope-name>  (no trailing slash)
# AZURE_AD_API_SCOPE_URI=api://your-client-id/access_as_user
