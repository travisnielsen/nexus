# Azure AI Foundry Configuration
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project-name
FOUNDRY_MODEL=gpt-4o-mini
FOUNDRY_AGENT_NAME=logistics-agent
# Optional for prompt-version pinning. Leave empty for default/current hosted version.
# FOUNDRY_AGENT_VERSION=

# Authentication
# AZURE_AD_CLIENT_ID: The Backend API app registration's Application (client) ID
AZURE_AD_CLIENT_ID=your-backend-api-client-id
# AZURE_AD_TENANT_ID: The Directory (tenant) ID shared across all app registrations
AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_API_SCOPE_URI: Fully qualified scope URI exposed by the Backend API app registration
# Format: api://<backend-app-guid>/<scope-name>  (no trailing slash)
# Must match NEXT_PUBLIC_AZURE_AD_API_SCOPE_URI in the frontend .env.local
AZURE_AD_API_SCOPE_URI=api://your-backend-app-id/access_as_user
AUTH_ENABLED=true

# Data dependencies
MCP_SERVER_URL=http://localhost:8001
RECOMMENDATIONS_AGENT_URL=http://localhost:5002

# OpenTelemetry / App Insights
ENABLE_INSTRUMENTATION=true
TELEMETRY_MODE=appinsights
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Experimental: can break streaming with some SDK combinations.
# Enable only when validating Foundry GenAI spans with a verified-compatible stack.
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=false
ENABLE_SENSITIVE_DATA=false
PATCH_AGUI_CONTEXT_SYNC=false

# =============================================================================
# Cosmos DB Configuration for session metadata
# =============================================================================
SESSION_METADATA_COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# Optional backward-compatible aliases:
# SESSION_METADATA_COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# SESSION_METADATA_COSMOS_DATABASE=logistics_session_metadata
# SESSION_METADATA_COSMOS_CONTAINER=sessions
# Note: Database/container are expected to be provisioned by Terraform, not runtime API bootstrap.