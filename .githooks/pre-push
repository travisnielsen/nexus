#!/usr/bin/env bash
# Run verification checks before push.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:/usr/local/bin:$PATH"

echo -e "${YELLOW}Running pre-push checks...${NC}"

if ! command -v uv >/dev/null 2>&1; then
  echo -e "${RED}Error: uv is not installed${NC}"
  exit 1
fi

# Run backend quality checks across all Python services.
if ! uv run --project . poe check; then
  echo -e "${RED}Python quality checks failed. Run 'uv run --project . poe check'.${NC}"
  exit 1
fi

# Run frontend lint if npm is available.
if command -v npm >/dev/null 2>&1; then
  echo "Running frontend lint..."
  if ! (cd src/frontend && npm run lint); then
    echo -e "${RED}Frontend lint failed. Run '(cd src/frontend && npm run lint)'.${NC}"
    exit 1
  fi
else
  echo -e "${YELLOW}Warning: npm not found; skipping frontend lint.${NC}"
fi

echo -e "${GREEN}Pre-push checks passed!${NC}"
